# 任意 OpenAI 兼容端点均可（DeepSeek / OpenAI / Kimi / GLM / 本地服务）
# 复制为 .env 并填入你的 key。也可直接设置 DEEPSEEK_API_KEY 或 OPENAI_API_KEY。
VIBE_CS101_BASE_URL=https://api.deepseek.com/v1
VIBE_CS101_API_KEY=
VIBE_CS101_MODEL=deepseek-chat

# Web UI 远程访问鉴权。默认不设置时仅允许本机 127.0.0.1 安全启动。
# 单用户：
# VIBE_CS101_AUTH_KEY=change-me
# 多用户（每个用户独立错题本和对话会话）：
# VIBE_CS101_AUTH_KEYS=alice:alice-key,bob:bob-key
# 长期多用户推荐改用（key 加盐哈希落盘，不走 .env 明文）：
#   python3 -m vibe_cs101 user add alice

# Web UI 限流（格式 N/秒数 或 N，窗口默认 60 秒；0 = 不限流）
# VIBE_CS101_RATE_API=120/60        # 每用户普通 API 频率
# VIBE_CS101_RATE_CHAT=10/60        # 每用户对话（LLM 调用）频率
# VIBE_CS101_RATE_AUTHFAIL=10/300   # 每 IP 鉴权失败次数（防暴力试 key）
